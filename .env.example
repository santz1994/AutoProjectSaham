MARKET_SYMBOLS=AAPL,SPY
TICKS_DB_PATH=data/ticks.db
MODELS_DIR=models
ML_TRAIN_INTERVAL=86400
# Optional Alpaca credentials (only used if you wire the real SDK)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://api.alpaca.markets
# Example .env for AutoSaham
# Copy to `.env` and fill values for local development

# Alpha Vantage (optional)
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here

# NewsAPI (optional)
NEWSAPI_KEY=your_newsapi_key_here

# Broker credentials (if using a live or paper broker)
BROKER_API_KEY=your_broker_api_key_here
BROKER_API_SECRET=your_broker_api_secret_here

# Prometheus pushgateway (optional)
PROMETHEUS_PUSHGATEWAY=http://localhost:9091

# Slack webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Email alerts (optional)
ALERT_EMAIL_TO=you@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass
# API keys and credentials
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
BROKER_API_KEY=
BROKER_API_SECRET=
DATABASE_URL=