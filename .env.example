# Example .env for AutoSaham
# Copy to `.env` and fill values for local development.

# Core runtime
MARKET_SYMBOLS=AAPL,SPY
TICKS_DB_PATH=data/ticks.db
MODELS_DIR=models
ML_TRAIN_INTERVAL=86400
DATABASE_URL=
AUTOSAHAM_STATE_REDIS_URL=
AUTOSAHAM_STATE_REDIS_PRIMARY_NAMESPACES=ai_regime_state,broker_connection,user_settings
AUTOSAHAM_STATE_REDIS_PRIMARY_SHADOW_SQLITE=1
AUTOSAHAM_STATE_POSTGRES_URL=
AUTOSAHAM_STATE_POSTGRES_AI_LOGS_ENABLED=1
AUTOSAHAM_STATE_POSTGRES_AI_LOGS_SHADOW_SQLITE=1

# Market/news API keys
NEWSAPI_KEY=
ALPHAVANTAGE_API_KEY=
ALPHA_VANTAGE_KEY=

# Broker credentials
BROKER_API_KEY=
BROKER_API_SECRET=
# Optional Alpaca credentials (only if Alpaca adapter is used)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://api.alpaca.markets

# Observability & notifications
PROMETHEUS_PUSHGATEWAY=http://localhost:9091
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=